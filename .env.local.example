# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — never expose client-side
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ACCESS_TOKEN=your-access-token
SUPABASE_DB_PASSWORD=your-db-password

# ── App URL ───────────────────────────────────────────────────────────────────
# Controls where invite/confirmation emails redirect to.
# Local dev:  http://localhost:3000
# Netlify:    https://phd-thesis-manager.netlify.app

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Admin bootstrap ───────────────────────────────────────────────────────────
# Set to "true" AFTER the first admin account is created via /setup.
# When set, the middleware skips the admin-exists check on every request.
# Netlify: add this env var and redeploy once bootstrapped.

# ADMIN_BOOTSTRAPPED=true
